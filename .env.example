# ============================================================
# Store Intelligence System - Environment Configuration
# Copy to .env and adjust as needed:  cp .env.example .env
# ============================================================

# --- API server ---
SIS_HOST=0.0.0.0
SIS_PORT=8000
SIS_LOG_LEVEL=info
SIS_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Database ---
# Default: local SQLite (zero-config). For production use TimescaleDB/Postgres:
# SIS_DATABASE_URL=postgresql+asyncpg://sis:sis@db:5432/sis
SIS_DATABASE_URL=sqlite+aiosqlite:///./store_intelligence.db

# --- Event streaming backend: "memory" (default, zero-dep) or "redis" ---
SIS_STREAM_BACKEND=memory
SIS_REDIS_URL=redis://localhost:6379/0
SIS_STREAM_NAME=sis.events

# --- Detection / tracking pipeline ---
# detector backend: "auto" (use YOLO if installed, else simulator) | "yolo" | "simulator"
SIS_DETECTOR_BACKEND=auto
SIS_YOLO_MODEL=yolov8n.pt
SIS_YOLO_CONF=0.35
SIS_VIDEO_SOURCE=               # path to a video file or RTSP url (kept OUT of git)
SIS_CAMERA_ID=cam-01
SIS_PROCESS_FPS=8               # target frames/sec to process
SIS_SIM_PEOPLE=18               # simulated concurrent shoppers (simulator backend)
SIS_SIM_SPEED=1.0               # simulation speed multiplier

# --- Analytics / anomaly thresholds ---
SIS_ANOMALY_ZSCORE=3.0
SIS_QUEUE_ALERT_LEN=6
SIS_DWELL_ALERT_SEC=180
SIS_OCCUPANCY_ALERT=40
